      textAlign: "center",
      marginBottom: 12,
    },
    ctaButton: {
      paddingHorizontal: 16,
      paddingVertical: 8,
      borderRadius: 20,
      backgroundColor: colors.buttonPrimaryBg,
    },
    ctaText: {
      color: "#fff",
      fontWeight: "800",
      fontSize: 14,
    },
  });