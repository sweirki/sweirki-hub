  shadowRadius: 4,
  elevation: 2,
},


    playerName: {
      color: colors.buttonSecondaryBg,
      fontSize: 18,
      fontWeight: "900",
    },
    playerSmall: {
      color: colors.text,
      fontSize: 12,
      marginTop: 2,
    },
 tabs: {
  flexDirection: "row",
  flexWrap: "wrap",
  justifyContent: "center",
  marginTop: 12,
  marginBottom: 8,
  columnGap: 6,
  rowGap: 6,
},

    tab: {
  borderWidth: 1,
  borderColor: colors.buttonPrimaryBg,
  backgroundColor: colors.card,
