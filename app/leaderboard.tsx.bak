import AsyncStorage from "@react-native-async-storage/async-storage";
const countryToFlag = (code: string = "US") => {
  if (!code) return "🏳️";
  return code
    .toUpperCase()
    .replace(/./g, char => String.fromCodePoint(127397 + char.charCodeAt(0)));
};


const xpToTier = (xp: number) => {
  if (xp >= 5000) return "💎";
  if (xp >= 3000) return "🥇";
  if (xp >= 1500) return "🥈";
  return "🥉";
};
function ScoreRow({
  item,
  index,
  colors,
  tab,
  rankJump,
  achievementLevel,
  sortMode,
  displayName,
}: {
  item: LeaderboardEntry;
  index: number;
  colors: any;
  tab: "daily" | "weekly" | "global" | "season" | "friends" | "local";
  rankJump?: number;
  achievementLevel?: number;
  sortMode?: string;
  displayName: string;
}) {



  const isCurrentUser =
    !!item.uid && !!auth.currentUser && item.uid === auth.currentUser.uid;

  // MOVED HOOKS HERE (LEGAL)
  const animatedPos = React.useRef(new Animated.Value(0)).current;
  const glowAnim = React.useRef(new Animated.Value(0)).current;
 const fadeAnim = React.useRef(new Animated.Value(0)).current;



  const bg =
    index === 0
      ? colors.gold
      : index === 1
      ? colors.silver
      : index === 2
      ? colors.bronze
      : colors.rankDefault;

  const entryStyle = [
    styles(colors).entry,
    { backgroundColor: bg },
    tab === "weekly" && isCurrentUser ? styles(colors).entryHighlight : null,
    rankJump !== null && isCurrentUser
      ? { transform: [{ scale: 1.03 }] }
      : null,
  ];

  // Slide animation
  if (isCurrentUser && rankJump !== null && rankJump !== 0) {
    Animated.timing(animatedPos, {
      toValue: rankJump * -12,
      duration: 400,
      useNativeDriver: true,
    }).start(() => {
      Animated.timing(animatedPos, {
        toValue: 0,
        duration: 300,
        useNativeDriver: true,
      }).start();
    });
  }

  // Glow animation
  if (isCurrentUser && rankJump !== null && rankJump !== 0) {
    glowAnim.setValue(0);
    Animated.timing(glowAnim, {
      toValue: 1,
      duration: 700,
      useNativeDriver: false,
    }).start(() => glowAnim.setValue(0));
  }

// Fade-in animation for CURRENT USER only
useEffect(() => {
  if (isCurrentUser) {
    Animated.timing(fadeAnim, {
      toValue: 1,
      duration: 450,
      useNativeDriver: true,
    }).start();
  }
}, []);


  const glowColor = glowAnim.interpolate({
  inputRange: [0, 1],
  outputRange: ["rgba(0,0,0,0)", colors.buttonSecondaryBg || "#FFD54F"],
});


  // PHASE 11: rank movement icon (current user only)
  let movementIcon = "";
  if (isCurrentUser && rankJump !== null) {
    if (rankJump > 0) {
      movementIcon = "↑";
    } else if (rankJump < 0) {
      movementIcon = "↓";
    }
  }

  const medal =
    index === 0 ? "🥇 " : index === 1 ? "🥈 " : index === 2 ? "🥉 " : "";


return (
  <Animated.View
    style={[
      {
        backgroundColor:
          index === 0
            ? "#FFE08A" // Gold
            : index === 1
            ? "#F1F1F4" // Silver
            : index === 2
            ? "#E6C4A8" // Bronze
            : "#FFFFFF", // Normal

        borderRadius: 14,
        overflow: "hidden",
        marginBottom: 10,
        paddingVertical: 10,
        paddingHorizontal: 14,

        shadowColor: "#000",
        shadowOpacity: isCurrentUser ? 0.15 : 0.06,
        shadowRadius: isCurrentUser ? 6 : 3,
        elevation: isCurrentUser ? 4 : 1,

        transform: [
          { translateY: animatedPos },
          isCurrentUser
            ? {
                scale: fadeAnim.interpolate({
                  inputRange: [0, 1],
                  outputRange: [0.96, 1],
                }),
              }
            : { scale: 1 },
        ],
      },
    ]}
  >
    {/* TOP ROW — Rank, Medal, Username */}
    <View style={{ flexDirection: "row", justifyContent: "space-between", alignItems: "center" }}>

      {/* Left block: Rank + Medal + Avatar + Username */}
      <View style={{ flexDirection: "row", alignItems: "center" }}>
        
        {/* Rank */}
        <Text style={{ fontWeight: "900", fontSize: 16, marginRight: 4 }}>
          #{index + 1}
        </Text>

        {/* Medal */}
        <Text style={{ fontSize: 18, marginRight: 8 }}>
          {medal}
        </Text>

        {/* Avatar Circle */}
        <View
          style={{
            width: 28,
            height: 28,
            borderRadius: 14,
            backgroundColor: "#EDEDED",
            justifyContent: "center",
            alignItems: "center",
            marginRight: 8,
          }}
        >
          <Text style={{ fontWeight: "700", fontSize: 14 }}>
         {displayName?.charAt(0)?.toUpperCase() || ""}

          </Text>
        </View>

  {/* USERNAME — RESOLVED AT RENDER TIME */}
<Text style={{ fontSize: 15, fontWeight: "700", color: "#333" }}>
  {displayName}
</Text>


      </View>

      {/* Movement Arrow */}
      {movementIcon !== "" && (
        <Text
          style={{
            fontSize: 18,
            fontWeight: "900",
            color: movementIcon === "↑" ? "#00C853" : "#D50000",
          }}
        >
          {movementIcon}
        </Text>
      )}
    </View>

    {/* SECOND ROW — STATS */}
  <View style={{ flexDirection: "row", marginTop: 6, gap: 18 }}>
  {/* DAILY → time only */}
  {tab === "daily" && item.time != null && (
    <Text style={{ color: "#444" }}>⏱ {item.time}s</Text>
  )}

  {/* WEEKLY / GLOBAL → score (XP) only */}
  {(tab === "weekly" || tab === "global") && (
    <Text style={{ color: "#444" }}>{item.score} XP</Text>
  )}

  {/* SEASON → season XP only */}
  {tab === "season" && (
    <Text style={{ color: "#444" }}>{item.score} XP</Text>
  )}
</View>



    {/* ACHIEVEMENT ICONS */}
    {item.achievements?.length > 0 && (
      <View style={{ flexDirection: "row", marginTop: 6 }}>
        {item.achievements.map((id, i) => {
          const data = ACHIEVEMENTS.find((a) => a.id === id);
          if (!data) return null;
          return (
            <Text key={i} style={{ fontSize: 16, marginRight: 6 }}>
              {data.icon}
            </Text>
          );
        })}
      </View>
    )}
  </Animated.View>
);


}


interface LeaderboardEntry {
  // 🔹 Basic identity
  username: string;     // from p.name
  uid?: string;         // from p.id

  // 🔹 Leaderboard metrics
  score: number;        // xp or seasonXP or daily/weekly score
  time: number;         // fastest time or 0
  streak?: number;      // from p.streak
  wins?: number;        // from p.wins

  // 🔹 Optional fields (for Daily/Weekly compatibility)
  difficulty?: string;
  date?: string;
  errors?: number;
  achievements?: string[];

  // 🔹 Optional location (for Local leaderboard)
  country?: string;
}

// 🔢 Hard ladder thresholds – next rank target
const getNextRankXP = (xp: number) => {
  if (xp < 2000) return 2000;      // Bronze → Silver
  if (xp < 5000) return 5000;      // Silver → Gold
  if (xp < 12000) return 12000;    // Gold → Platinum
  if (xp < 25000) return 25000;    // Platinum → Diamond
  if (xp < 50000) return 50000;    // Diamond → Master
  if (xp < 100000) return 100000;  // Master → Grandmaster
  return 100000;                   // cap
};

export default function Leaderboard() {
  const [usernameMap, setUsernameMap] = useState<Record<string, string>>({});
  useEffect(() => {
  const loadUsername = async () => {
    const user = auth.currentUser;
    if (!user) return;

    const snap = await getDoc(doc(db, "users", user.uid));
    if (snap.exists()) {
      const data = snap.data();
      if (typeof data.username === "string" && data.username.length > 0) {
        setUsername(data.username);
        return;
      }
    }

    // Fallback (never UID)
    setUsername("Player");
  };

  loadUsername();
}, []);

// ✅ LOAD USERNAME MAP ONCE (SOURCE OF TRUTH)
useEffect(() => {
  let cancelled = false;

  const loadUsernameMap = async () => {
    try {
      const snap = await getDocs(collection(db, "users"));
      const map: Record<string, string> = {};

      snap.forEach((doc) => {
        const data = doc.data();
     map[doc.id] =
  data.username ||
  data.displayName ||
  data.name ||
  data.email ||
  "Player";


      });

      if (!cancelled) {
        setUsernameMap(map);
      }
    } catch (e) {
      console.warn("⚠️ Failed to load username map:", e);
    }
  };

  loadUsernameMap();
  return () => {
    cancelled = true;
  };
}, []);

   const currentUID = auth.currentUser?.uid ?? null;
const resolveUsername = (uid?: string, rank?: number) => {
  if (!uid) return "Anonymous";

  // current user
  if (uid === currentUID) return myUsername;

  const name = usernameMap[uid];

  // canonical usernames only (letters + numbers, reasonable length)
  if (name && /^[a-zA-Z0-9_]{3,20}$/.test(name)) {
    return name;
  }

  // anonymized fallback
  return `Anonymous #${rank ?? "—"}`;
};

const myUsername = usernameMap[currentUID || ""] || "You";
  const today = new Date().toISOString().split("T")[0];

  const {
    rows: dailyRows,
    loading: loadingDailyFeed,
    userRank: dailyUserRank,
  } = useLeaderboardFeed("daily", {
    date: today,
    uid: currentUID ?? undefined,
  });
  const colors = getColors();
 const achievementLevel = useAchievementsStore((s) => s.getLevel());
const progress = useAchievementsStore((s) => s.getProgressPercent());
const flashAnim = useRef(new Animated.Value(0)).current;
const xpAnim = useRef(new Animated.Value(0)).current;
const [xpGain, setXpGain] = useState(0);
const xpGainAnim = useRef(new Animated.Value(0)).current;
  // (PHASE 4 — STEP 4A)


const tierBadge: any = {
  Bronze: "🥉",
  Silver: "🥈",
  Gold: "🥇",
  Platinum: "💠",
  Diamond: "💎",
  Master: "🔥",
  Grandmaster: "👑",
};


 // main tab the user selects visually
const [mainTab, setMainTab] = useState<"daily" | "weekly" | "global" | "season">("daily");

// actual tab the list displays
const [tab, setTab] = useState<"daily" | "weekly" | "friends" | "global" | "local" | "season">("daily");



  const [dailyScores, setDailyScores] = useState<LeaderboardEntry[]>([]);
  const [weeklyScores, setWeeklyScores] = useState<LeaderboardEntry[]>([]);
  const [friendScores, setFriendScores] = useState<LeaderboardEntry[]>([]);
  const [globalScores, setGlobalScores] = useState<LeaderboardEntry[]>([]);
  const [localScores, setLocalScores] = useState<LeaderboardEntry[]>([]);
  const [seasonScores, setSeasonScores] = useState<LeaderboardEntry[]>([]);
const [loadingSeason, setLoadingSeason] = useState(false);


  const [loadingDaily, setLoadingDaily] = useState(false);
  const [loadingWeekly, setLoadingWeekly] = useState(false);
  const [loadingFriends, setLoadingFriends] = useState(false);
  const [loadingGlobal, setLoadingGlobal] = useState(false);
  const [loadingLocal, setLoadingLocal] = useState(false);

// LIVE RANK ANIMATION
const [previousRank, setPreviousRank] = useState<number | null>(null);
const [rankJump, setRankJump] = useState<number | null>(null);
const [showConfetti, setShowConfetti] = useState(false);
const [particles, setParticles] = useState<any[]>([]);
const [currentSeason, setCurrentSeason] = useState<number | null>(null);
const [seasonStart, setSeasonStart] = useState<number | null>(null);
const [seasonEnd, setSeasonEnd] = useState<number | null>(null);
 const [seasonCountdown, setSeasonCountdown] = useState("");
const listRef = React.useRef<FlatList>(null);
const router = useRouter();
const [sortMode, setSortMode] = useState<"xp" | "streak" | "wins" | "time" | null>(null);
const [weeklyRaw, setWeeklyRaw] = useState<any[]>([]);

// ✅ BUILD WEEKLY SCORES FROM RAW + USERS (SOURCE OF TRUTH)
useEffect(() => {
  if (!weeklyRaw.length) return;
  if (!globalScores.length) return;

  const rows: LeaderboardEntry[] = weeklyRaw.map((data: any) => {
    const uid = data.uid || data.userId || data.id;

    const user = globalScores.find((p) => p.uid === uid);

    return {
      uid,
   username: resolveUsername(uid),
      score: data.score ?? data.xp ?? 0,
      time: data.time ?? 0,

      streak: user?.streak ?? 0,
      wins: user?.wins ?? 0,
      achievements: user?.achievements ?? [],
    };
  });

  setWeeklyScores(rows);
}, [weeklyRaw, globalScores, usernameMap, myUsername]);

 const [playerStats, setPlayerStats] = useState<any>({
  username: "",
  dailyStreak: 0,
  weeklyWins: 0,
  totalScore: 0,
  totalTime: 0,

  globalRank: null,       // NEW
  bestGlobalRank: null,   // NEW
  tier: "Bronze",         // NEW
});

const nextRankXP = getNextRankXP(playerStats.ladderXP || 0);

  // Load player stats from local storage

  // CREATE PARTICLES WHEN CONFETTI STARTS
useEffect(() => {
  if (!showConfetti) return;

  const temp = Array.from({ length: 15 }).map(() => ({
    id: Math.random().toString(),
    left: Math.random() * 300,
    delay: Math.random() * 500,
  }));

  setParticles(temp);
}, [showConfetti]);



// ANIMATE PARTICLES FALLING
useEffect(() => {
  if (!showConfetti) return;

  const interval = setInterval(() => {
    setParticles((prev) =>
      prev.map((p) => ({
        ...p,
        delay: p.delay + 40,
      }))
    );
  }, 30);

  setTimeout(() => clearInterval(interval), 1200);

  return () => clearInterval(interval);
}, [showConfetti]);

// 🔥 Fetch current season metadata
useEffect(() => {
  const fetchSeason = async () => {
    try {
      const ref = doc(db, "seasonMeta", "current");
      const snap = await getDoc(ref);

      if (snap.exists()) {
        const data = snap.data();
      setCurrentSeason(data.season);
setSeasonStart(data.start);
setSeasonEnd(data.end);


      }
    } catch (err) {
      console.log("❌ Season fetch error:", err);
    }
  };

  fetchSeason();
}, []);




useEffect(() => {
  if (!seasonEnd) return;

  const tick = () => {
    const now = Date.now();
    const diff = seasonEnd - now;

    if (diff <= 0) {
      setSeasonCountdown("Ends now!");
      return;
    }

    const d = Math.floor(diff / (1000 * 60 * 60 * 24));
    const h = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const m = Math.floor((diff / (1000 * 60)) % 60);
    const s = Math.floor((diff / 1000) % 60);

    setSeasonCountdown(`${d}d ${h}h ${m}m ${s}s`);
  };

  tick();
  const interval = setInterval(tick, 1000);
  return () => clearInterval(interval);
}, [seasonEnd]);

// (PHASE 4) Season rollover logic removed from UI

// (PHASE 4) Season mutation REMOVED
// Season lifecycle must be handled by backend / admin / cloud function


 // Load basic user stats
useEffect(() => {
  const loadStats = async () => {
    try {
  let username = "Player";

// Prefer Firestore user profile (REAL source of truth)
if (currentUID) {
  try {
    const userSnap = await getDoc(doc(db, "users", currentUID));
    if (userSnap.exists()) {
      const u = userSnap.data() as any;
      const candidate =
        (u.username || u.displayName || u.name || u.email || "").toString().trim();

      if (candidate.length > 0) {
        username = candidate;
        // keep AsyncStorage in sync so older UI reads don’t show UID
        await AsyncStorage.setItem("username", username);
      }
    }
  } catch (e) {
    // ignore, fallback below
  }
}

// fallback to cached (but ONLY if it doesn't look like a UID)
if (username === "Player") {
  const cached = (await AsyncStorage.getItem("username")) || "";
  const c = cached.trim();
  // if it looks like a Firebase UID (long random string), do NOT use it as a name
  if (c.length > 0 && c.length < 24) username = c;
}


// Load full structured stats
const localStatsRaw = await AsyncStorage.getItem("playerStats");
const localStats = localStatsRaw ? JSON.parse(localStatsRaw) : null;

// Default fallback
const stats = localStats || {
  totalGames: 0,
  totalWins: 0,
  fastestTime: 0,
  totalErrors: 0,
  totalHints: 0,
  streak: 0,
  bestStreak: 0,
  ladderXP: 0,
  ladderRank: "Bronze",
};
// Load Ladder XP (from ladderUsers)
try {
  const uid = currentUID;
  if (uid) {
    const xpRef = doc(db, "ladderUsers", uid);
    const xpSnap = await getDoc(xpRef);
    if (xpSnap.exists()) {
      const xp = xpSnap.data()?.xp || 0;
      stats.ladderXP = xp;
      if (playerStats && stats.ladderXP > playerStats.ladderXP) {
  const gained = stats.ladderXP - playerStats.ladderXP;
  setXpGain(gained);

  xpGainAnim.setValue(0);
  Animated.timing(xpGainAnim, {
    toValue: 1,
    duration: 800,
    useNativeDriver: true,
  }).start(() => setXpGain(0));
}


      // Rank Calculation
      if (xp >= 2000) stats.ladderRank = "Master";
      else if (xp >= 1500) stats.ladderRank = "Diamond";
      else if (xp >= 1000) stats.ladderRank = "Platinum";
      else if (xp >= 600) stats.ladderRank = "Gold";
      else if (xp >= 300) stats.ladderRank = "Silver";
      else stats.ladderRank = "Bronze";
    }
  }
} catch (err) {
  console.warn("⚠️ Failed loading XP:", err);
}

// Achievement Level
const achievementLevel = useAchievementsStore.getState().getLevel();

 // Send to UI
   setPlayerStats({
     username,
     streak: stats.streak,
     bestStreak: stats.bestStreak,
     games: stats.totalGames,
     wins: stats.totalWins,
     fastestTime: stats.fastestTime,
     ladderXP: stats.ladderXP,
    ladderRank: getLadderRank(stats.ladderXP),
     achievementLevel,
   });
// Rank-up flash
if (playerStats && stats.ladderRank !== playerStats.ladderRank) {
  Animated.sequence([
    Animated.timing(flashAnim, {
      toValue: 1,
      duration: 250,
      easing: Easing.out(Easing.ease),
      useNativeDriver: true,
    }),
    Animated.timing(flashAnim, {
      toValue: 0,
      duration: 400,
      easing: Easing.in(Easing.ease),
      useNativeDriver: true,
    }),
  ]).start();
}
// Animate XP bar
Animated.timing(xpAnim, {
  toValue: stats.ladderXP,
  duration: 600,
  easing: Easing.out(Easing.ease),
  useNativeDriver: false,
}).start();

   // Debug
   console.log("📊 FINAL LADDER STATS LOADED:", { username, stats });
 } catch (err) {
      console.warn("⚠️ Failed to load base stats:", err);
    }
  };

  loadStats();
}, []);

// /* Load ALL players from /users for Global / Local / Season / Friends */
// ✅ Fetch Global leaderboard from canonical collection
useEffect(() => {
  setLoadingGlobal(true);

  const q = query(collection(db, "leaderboard"), orderBy("xp", "desc"));

  const unsub = onSnapshot(
    q,
    (snap) => {
      const rows: LeaderboardEntry[] = snap.docs.map((d, index) => {
        const data = d.data() as any;
        return {
          uid: d.id,
          username: resolveUsername(d.id, index + 1),
          score: data.xp ?? 0,
          wins: data.wins ?? 0,
          streak: data.streak ?? 0,
          time: 0,
        };
      });

      setGlobalScores(rows);
      setLoadingGlobal(false);
    },
    (e) => {
      console.error("⚠️ Global leaderboard error:", e);
      setLoadingGlobal(false);
    }
  );

  return () => unsub();
}, [usernameMap]);




// ⭐ Fetch Seasonal leaderboard
useEffect(() => {
  if (tab !== "season") return;

  setLoadingSeason(true);

  (async () => {
    try {
      // Get current season #
      const seasonMeta = await getDoc(doc(db, "seasonMeta", "current"));
      if (!seasonMeta.exists()) {
        setSeasonScores([]);
        setLoadingSeason(false);
        return;
      }
      const season = seasonMeta.data().season;

      // Read ALL documents from seasonLeaderboard
      const ref = collection(db, "seasonLeaderboard");
      const snap = await getDocs(ref);

      const rows: any[] = [];
      snap.forEach((doc) => {
        const data = doc.data();
        if (data.season === season) rows.push(data);
      });

      // Sort by score DESC
      rows.sort((a, b) => b.score - a.score);

 setSeasonScores(
  rows.map((row) => ({
    ...row,
 username: resolveUsername(row.uid),
  }))
);
      setLoadingSeason(false);
    } catch (e) {
      console.error("⚠️ Season leaderboard error:", e);
      setSeasonScores([]);
      setLoadingSeason(false);
    }
  })();
}, [tab]);



  // Load Local leaderboard from AsyncStorage
  useEffect(() => {
    if (tab !== "local") return;

    const loadLocal = async () => {
      try {
        setLoadingLocal(true);
        const raw = await AsyncStorage.getItem("localLeaderboard");
        if (!raw) {
          setLocalScores([]);
          setLoadingLocal(false);
          return;
        }
        const parsed: LeaderboardEntry[] = JSON.parse(raw);
        parsed.sort((a, b) => b.score - a.score);
        setLocalScores(parsed);
        setLoadingLocal(false);
      } catch (e) {
        console.log("⚠️ Local leaderboard error:", e);
        setLocalScores([]);
        setLoadingLocal(false);
      }
    };

    loadLocal();
  }, [tab]);


  // Fetch Friends leaderboard
  useEffect(() => {
    if (tab !== "friends" || !auth.currentUser) return;

    setLoadingFriends(true);

    (async () => {
      try {
        const uid = auth.currentUser!.uid;
        const friendSnap = await getDocs(
          collection(db, "friends", uid, "list")
        );

        const friendUIDs = friendSnap.docs.map((d) => d.id);

        if (friendUIDs.length === 0) {
        setFriendScores([]);

          setLoadingFriends(false);
          return;
        }

        const q = query(
          collection(db, "weeklyLeaderboard"),
          where("uid", "in", friendUIDs),
          orderBy("score", "desc")
        );

        const unsub = onSnapshot(q, (snap) => {
       const scores: LeaderboardEntry[] = snap.docs.map(
  (d) => ({
    uid: d.id,
    ...(d.data() as LeaderboardEntry),
  })
);

setFriendScores(
  scores.map((row) => ({
    ...row,
username: resolveUsername(row.uid),
  }))
);
 setLoadingFriends(false);
        });

        return () => unsub();
      } catch (e) {
        console.error("⚠️ Friends leaderboard error:", e);
        setLoadingFriends(false);
      }
    })();
  }, [tab]);

 useEffect(() => {
  if (previousRank === null) return;
  if (!listRef.current) return;

  // ❗ Prevent crash when Firestore is offline and index = -1
  if (previousRank < 0) return;

  // Small delay helps list render correctly first
  setTimeout(() => {
    try {
      listRef.current?.scrollToIndex({
        index: previousRank,
        animated: true,
      });
    } catch (err) {
      console.warn("⚠️ scrollToIndex failed:", err);
    }
  }, 200);
}, [previousRank, tab]);

   // ⭐ SORT LOGIC GOES HERE
let scoresToRender =
  tab === "daily"
    ? dailyScores
    : tab === "weekly"
    ? weeklyScores
    : tab === "friends"
    ? friendScores
    : tab === "global"
    ? globalScores
    : tab === "local"
    ? localScores
    : seasonScores;

if (sortMode) {
  scoresToRender = [...scoresToRender].sort((a, b) => {
    switch (sortMode) {
      case "xp":
        case "xp":
  return (b.score || 0) - (a.score || 0);

   
      case "time":
        return (a.time || 9999) - (b.time || 9999);
      default:
        return 0;
    }
  });
}
  const renderScore = ({ item, index }) => (

  <TouchableOpacity
  onPress={() => {
    if (item.uid) {
      router.push(`/profile?uid=${item.uid}`);
    }
  }}
>
<ScoreRow
  item={{
    ...item,
    score: item.xp ?? item.score ?? 0,
    time: item.time ?? 0,
    streak: item.streak ?? 0,
    wins: item.wins ?? 0,
  }}
  index={index}
  colors={colors}
  tab={tab}
  rankJump={rankJump}
  achievementLevel={achievementLevel}
  sortMode={sortMode}   // ⭐ ADD THIS LINE
  displayName={resolveUsername(item.uid, index + 1)}
/>

</TouchableOpacity>

);


  return (

  <ImageBackground
  source={require("../assets/bg.png")}
  style={styles(colors).bg}
  resizeMode="cover"
>
    {showConfetti && (
      <View
        style={{
          position: "absolute",
          top: 0,
          left: 0,
          right: 0,
          height: 200,
          zIndex: 999,
          elevation: 999,
        }}
      >
        {/* PARTICLES GO HERE NEXT STEP */}
        
        {particles.map((p) => (
  <View
    key={p.id}
    style={{
      position: "absolute",
      top: 0,
      left: p.left,
      width: 6,
      height: 6,
      borderRadius: 3,
      backgroundColor: colors.buttonSecondaryBg,
      opacity: 0.9,
      transform: [{ translateY: p.delay / 4 }],
    }}
  />
))}


      </View>
    )}
      
   <View style={[styles(colors).overlay, { paddingHorizontal: 0 }]}>
<View
  style={{
    width: "92%",
    alignSelf: "center",
  }}
>


       {/* 🔥 PREMIUM PLAYER BANNER */}
<Animated.View
  style={[
    styles(colors).playerCard,
    {
      shadowOpacity: flashAnim.interpolate({
        inputRange: [0, 1],
        outputRange: [0.15, 0.9],
      }),
      transform: [
        {
          scale: flashAnim.interpolate({
            inputRange: [0, 1],
            outputRange: [1, 1.03],
          }),
        },
      ],
    },
  ]}
>

 <Text style={styles.playerName}>
  {playerStats.username || "Player"}
</Text>


  {xpGain > 0 && (
  <Animated.Text
    style={{
      position: "absolute",
      right: 12,
      top: -4,
      fontSize: 16,
      fontWeight: "900",
      color: "#00ff87",
      opacity: xpGainAnim.interpolate({
        inputRange: [0, 1],
        outputRange: [1, 0],
      }),
      transform: [
        {
          translateY: xpGainAnim.interpolate({
            inputRange: [0, 1],
            outputRange: [0, -20],
          }),
        },
      ],
    }}
  >
    +{xpGain} XP
  </Animated.Text>
)}


  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>🏅 Rank:</Text>
    
    <Text style={styles(colors).statValue}>
  {playerStats.ladderRank === "Grandmaster"
    ? "👑"
    : playerStats.ladderRank === "Master"
    ? "🔱"
    : playerStats.ladderRank === "Diamond"
    ? "💎"
    : playerStats.ladderRank === "Platinum"
    ? "💠"
    : playerStats.ladderRank === "Gold"
    ? "🥇"
    : playerStats.ladderRank === "Silver"
    ? "🥈"
    : "🥉"}{" "}
  {playerStats.ladderRank} ({playerStats.ladderXP} XP)
</Text>

    {/* Rank XP Progress */}
<View style={{ marginTop: 6, marginBottom: 6 }}>
  <Text style={{ color: colors.text, fontSize: 12, fontWeight: "700" }}>
    Rank Progress:
  </Text>

  <View
    style={{
      height: 10,
      backgroundColor: "rgba(0,0,0,0.15)",
      borderRadius: 6,
      marginTop: 4,
      width: "100%",
      overflow: "hidden",
    }}
  >
    <View
      style={{
        height: "100%",
        width: `${Math.min(
  (playerStats.ladderXP / nextRankXP) * 100,
  100
)}%`,

        backgroundColor: colors.buttonPrimaryBg,
      }}
    />
  </View>

  <Text style={{ fontSize: 11, color: colors.text, marginTop: 2 }}>
  {playerStats.ladderXP} / {nextRankXP} XP
</Text>

</View>

  </View>

  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>🔥 Streak:</Text>
    <Text style={styles(colors).statValue}>{playerStats.streak}</Text>
  </View>

  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>🏆 Wins:</Text>
    <Text style={styles(colors).statValue}>
      {playerStats.wins} / {playerStats.games}
    </Text>
  </View>

  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>⚡ Best Streak:</Text>
    <Text style={styles(colors).statValue}>{playerStats.bestStreak}</Text>
  </View>

  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>⏱ Fastest Time:</Text>
    <Text style={styles(colors).statValue}>
      {playerStats.fastestTime}s
    </Text>
  </View>

  <View style={styles(colors).statRow}>
    <Text style={styles(colors).playerSmall}>🎖 Achievement Tier:</Text>
    {/* Achievement Badges Row */}
<View style={{ marginTop: 6, flexDirection: "row", flexWrap: "wrap" }}>
  {playerStats.achievements && playerStats.achievements.length > 0 ? (
    playerStats.achievements.map((a, index) => (
      <Text
        key={index}
        style={{ fontSize: 18, marginRight: 6, marginBottom: 4 }}
      >
        {a.icon}
      </Text>
    ))
  ) : (
    <Text style={{ fontSize: 12, color: colors.text }}>
      No badges unlocked yet.
    </Text>
  )}
</View>

    <Text style={styles(colors).statValue}>
      {playerStats.achievementLevel} {tierBadge[playerStats.achievementLevel]}
    </Text>
  </View>
 <View style={{ marginTop: 12, paddingBottom: 6 }}>
  <Text style={{ color: colors.text, fontSize: 12, fontWeight: "700" }}>
   📈 Achievement Progress: {Math.floor(progress)}%
  </Text>

  <View
    style={{
     height: 10,
backgroundColor: "rgba(0,0,0,0.15)",   // darker, visible
      borderRadius: 6,
      marginTop: 4,
      width: "100%",
      overflow: "hidden",
    }}
  >
    <View
      style={{
        height: "100%",
      width: `${Math.max(progress, 20)}%`,   // <--- MINIMUM 4%
       backgroundColor: colors.primary, // brightest blue, always visible

      }}
    />
  </View>
</View>
{/* Season Panel */}
<View style={{ marginTop: 14 }}>
  <Text style={{ fontSize: 15, fontWeight: "800", color: colors.text }}>
  🏆 Season Stats
</Text>


  <View style={{ flexDirection: "row", justifyContent: "space-between", marginTop: 6 }}>
    <Text style={{ color: colors.text, fontSize: 12 }}>Rank:</Text>
    <Text style={{ color: colors.text, fontWeight: "700" }}>
      {playerStats.seasonRank || "--"}
    </Text>
  </View>

  <View style={{ flexDirection: "row", justifyContent: "space-between", marginTop: 4 }}>
    <Text style={{ color: colors.text, fontSize: 12 }}>XP:</Text>
    <Text style={{ color: colors.text, fontWeight: "700" }}>
  {playerStats.seasonXP ?? 0}
</Text>
<Text style={{ color: colors.text, fontSize: 12, marginTop: 6 }}>
  ⏳ Season ends in: {seasonCountdown}
</Text>

  </View>

  {/* Season XP Progress Bar */}
  <View
    style={{
      height: 10,
      backgroundColor: "rgba(0,0,0,0.15)",
      borderRadius: 6,
      marginTop: 4,
      width: "100%",
      overflow: "hidden",
    }}
  >
  <Animated.View
  style={{
    height: "100%",
    backgroundColor: colors.buttonPrimaryBg,
    transform: [
      {
        scaleX: xpAnim.interpolate({
          inputRange: [0, 3000],
          outputRange: [0, 1],
        }),
      },
    ],
    transformOrigin: "left",
  }}
/>


  </View>

  <Text style={{ fontSize: 11, color: colors.text, marginTop: 2 }}>
    {playerStats.seasonXP || 0} / 3000 XP
  </Text>

  <View style={{ flexDirection: "row", justifyContent: "space-between", marginTop: 6 }}>
    <Text style={{ color: colors.text, fontSize: 12 }}>Wins:</Text>
    <Text style={{ color: colors.text, fontWeight: "700" }}>
      {playerStats.seasonWins || 0} / {playerStats.seasonGames || 0}
    </Text>
  </View>
</View>

</Animated.View>

{/* 🔥 PREMIUM SEGMENTED TABS */}
<View style={styles(colors).tabs}>
  {["daily", "weekly", "global", "season"].map((t) => {
    const active = tab === t;
    return (
      <TouchableOpacity
        key={t}
        onPress={() => {
          setRankJump(null);
          setPreviousRank(null);
          setShowConfetti(false);
setSortMode(null);    // reset sorter
         setMainTab(t as any);
setTab(t as any);

if (t === "season") {
  setLoadingSeason(true);
}

        }}
        style={[
          styles(colors).tab,
          active && styles(colors).tabActive,
        ]}
      >
        <Text
          style={[
            styles(colors).tabText,
            active && styles(colors).tabTextActive,
          ]}
        >
          {t.toUpperCase()}
        </Text>
      </TouchableOpacity>
    );
  })}
</View>


{/* SECONDARY TABS (Friends / Local) */}
{mainTab === "global" || mainTab === "weekly" ? (
  <View style={{ flexDirection: "row", justifyContent: "center", marginTop: 2 }}>
    <TouchableOpacity
      onPress={() => setTab("friends")}
      style={{
        backgroundColor: tab === "friends" ? colors.buttonPrimaryBg : colors.card,
        paddingVertical: 6,
        paddingHorizontal: 14,
        borderRadius: 12,
        marginHorizontal: 6,
      }}
    >
      <Text style={{ 
        color: tab === "friends" ? "#fff" : colors.text,
        fontWeight: "700",
      }}>
        FRIENDS
      </Text>
    </TouchableOpacity>

    <TouchableOpacity
      onPress={() => setTab("local")}
      style={{
        backgroundColor: tab === "local" ? colors.buttonPrimaryBg : colors.card,
        paddingVertical: 6,
        paddingHorizontal: 14,
        borderRadius: 12,
        marginHorizontal: 6,
      }}
    >
      <Text style={{
        color: tab === "local" ? "#fff" : colors.text,
        fontWeight: "700",
      }}>
        LOCAL
      </Text>
    </TouchableOpacity>
  </View>
  
) : null}

{/* ⭐ SORT BAR */}
{scoresToRender.length > 1 && (
  <View
    style={{
      flexDirection: "row",
      justifyContent: "center",
      marginTop: 10,
      marginBottom: 16,
    }}
  >
  {[
  ...(tab === "daily" ? [{ key: "time", label: "Time" }] : []),
  ...(tab !== "daily" ? [{ key: "xp", label: "XP" }] : []),
].map((b) => (

      <TouchableOpacity
        key={b.key}
        onPress={() => setSortMode(b.key)}
        style={{
          backgroundColor:
            sortMode === b.key ? colors.buttonPrimaryBg : colors.card,
          paddingVertical: 6,
          paddingHorizontal: 12,
          borderRadius: 12,
          marginHorizontal: 4,
        }}
      >
        <Text
          style={{
            color: sortMode === b.key ? "#fff" : colors.text,
            fontWeight: "700",
          }}
        >
          {b.label}
        </Text>
      </TouchableOpacity>
    ))}
  </View>
)}

   
</View>
{/* SPACE BETWEEN SORT BAR AND LIST */}
<View style={{ height: 20 }} />


{/* RANK JUMP MESSAGE */}

{rankJump !== null && rankJump !== 0 && (
  <View style={{ alignItems: "center", marginBottom: 6 }}>
    <Text
      style={{
        color: rankJump > 0 ? colors.buttonSecondaryBg : "red",
        fontWeight: "900",
        fontSize: 14,
      }}
    >
      {rankJump > 0
        ? `⬆️ You moved up +${rankJump} places!`
        : `⬇️ You dropped ${Math.abs(rankJump)} places`}
    </Text>
  </View>
)}

{/* CONFETTI TRIGGER */}
{rankJump !== null && rankJump > 0 && (
  <View style={{ height: 0, width: 0 }}>
    {/* Placeholder: confetti will be drawn absolutely over screen */}
  </View>
)}

    {/* LISTS */}
{
  tab === "daily" && loadingDailyFeed ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "weekly" && loadingWeekly ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "friends" && loadingFriends ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "global" && loadingGlobal ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "local" && loadingLocal ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "season" && loadingSeason ? (
    <ActivityIndicator size="large" color={colors.primary} />
  ) : tab === "daily" && dailyScores.length === 0 ? (
    <View style={styles(colors).emptyState}>
      <Text style={styles(colors).emptyTitle}>
        You have no daily results yet.
      </Text>
      <Text style={styles(colors).emptyText}>
        Play today&apos;s challenge and your score will appear here.
      </Text>
      <TouchableOpacity
        style={styles(colors).ctaButton}
       onPress={() => {
  router.push("/daily"); // adjust route if needed
}}

      >
        <Text style={styles(colors).ctaText}>
          Play Today&apos;s Challenge
        </Text>
      </TouchableOpacity>
    </View>
  ) : (
    <FlatList
      ref={listRef}
      data={scoresToRender}
      keyExtractor={(item) => item.uid ?? Math.random().toString()}
      key={tab}
      renderItem={renderScore}
      style={styles(colors).list}
    />
  )
}

</View>
  
    </ImageBackground>
  );
}

const styles = (colors: any) =>
  StyleSheet.create({
    bg: {
      flex: 1,
      width: "100%",
    },
  overlay: {
  flex: 1,
  backgroundColor: "rgba(0,0,0,0.25)",
  paddingVertical: 12,
},

playerCard: {
  backgroundColor: colors.card,
  borderRadius: 16,
  padding: 14,
  borderWidth: 1,
  borderColor: colors.buttonPrimaryBg,
