  alignItems: "center",
  justifyContent: "center",
  paddingHorizontal: 16,
  paddingTop: 20,
},

    emptyTitle: {
      color: "#ffffff",
      fontSize: 18,
      fontWeight: "800",
      marginBottom: 6,
      textAlign: "center",
    },
    emptyText: {
